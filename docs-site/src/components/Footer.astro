---
import type { Props } from '@astrojs/starlight/props';
import Pagination from 'virtual:starlight/components/Pagination';
---

<Pagination {...Astro.props} />

<footer class="hs-footer">
  <div class="hs-footer__inner">
    <div class="hs-footer__top">
      <div>
        <p class="hs-footer__label">hs108 / Docs</p>
        <p class="hs-footer__desc">
          Brand documentation, design tokens, typography, and component reference
          for hs108 Design Studio.
        </p>
      </div>

      <nav class="hs-footer__nav">
        <div>
          <p class="hs-footer__nav-label">Pages</p>
          <div class="hs-footer__nav-links">
            <a href="/" class="hs-footer__link">Introduction</a>
            <a href="/tokens/overview" class="hs-footer__link">Design Tokens</a>
            <a href="/typography/overview" class="hs-footer__link">Typography</a>
            <a href="/components/overview" class="hs-footer__link">Components</a>
          </div>
        </div>
        <div>
          <p class="hs-footer__nav-label">Studio</p>
          <div class="hs-footer__nav-links">
            <a href="https://hs108.in" class="hs-footer__link">hs108.in ↗</a>
            <a href="https://field-notes.hs108.in" class="hs-footer__link">Field Notes ↗</a>
          </div>
        </div>
      </nav>
    </div>

    <hr class="hs-footer__hr" />

    <div class="hs-footer__bottom">
      <span>© {new Date().getFullYear()} HS108 Design Studio</span>
      <span>docs.hs108.in</span>
    </div>
  </div>
</footer>

<style>
  .hs-footer {
    border-top: var(--hs-border-width) solid var(--hs-border);
    margin-top: 3rem;
  }

  .hs-footer__inner {
    padding-block: 3rem 2rem;
  }

  .hs-footer__top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 3rem;
    margin-bottom: 3rem;
  }

  .hs-footer__label {
    font-family: 'Geist Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    opacity: 0.35;
    margin-bottom: 0.5rem;
  }

  .hs-footer__desc {
    font-size: 13px;
    opacity: 0.5;
    max-width: 40ch;
    line-height: 1.55;
    color: var(--sl-color-text);
  }

  .hs-footer__nav {
    display: flex;
    gap: 3rem;
    flex-shrink: 0;
  }

  .hs-footer__nav-label {
    font-family: 'Geist Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    opacity: 0.35;
    margin-bottom: 0.75rem;
  }

  .hs-footer__nav-links {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .hs-footer__link {
    font-family: 'Geist Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--sl-color-text);
    transition: background 150ms ease, color 150ms ease;
    display: inline-block;
  }

  .hs-footer__link:hover {
    color: var(--sl-color-accent);
  }

  .hs-footer__hr {
    border: none;
    border-top: var(--hs-border-width) solid var(--hs-border-soft);
    margin-bottom: 1.5rem;
  }

  .hs-footer__bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
    font-family: 'Geist Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    opacity: 0.3;
    color: var(--sl-color-text);
  }

  @media (max-width: 640px) {
    .hs-footer__top {
      flex-direction: column;
      gap: 2rem;
    }
    .hs-footer__bottom {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
